{
  "version": 2,
  "installCommand": "python -m pip install --break-system-packages -r requirements.txt",
  "buildCommand": "python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "petrescue/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "petrescue/wsgi.py"
    }
  ]
}
